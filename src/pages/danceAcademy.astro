---
import Layout from '~/layouts/PageLayout.astro';

import { t } from 'i18next';
import Video from '~/components/react/Video';
import { NAV_LINKS_ACADEMY_MAP } from '~/constants/commons';
import News from '~/components/widgets/academy/News.astro';
import Calendar from '~/components/widgets/academy/Calendar.astro';

const metadata = {
  title: t('academy.title'),
};
---

<Layout metadata={metadata}>
  <Video
    client:idle
    id={NAV_LINKS_ACADEMY_MAP.HOME.href.replace('#', '')}
    noSupport={t('video.noSupport')}
    creative={t('academy.video.creative')}
    culture={t('academy.video.culture')}
  />

  <News id={NAV_LINKS_ACADEMY_MAP.NEWS.href.replace('#', '')} />
  <Calendar id={NAV_LINKS_ACADEMY_MAP.CALENDAR.href.replace('#', '')} />
</Layout>

---
import WidgetWrapper from '../../ui/WidgetWrapper.astro';
import type { Widget } from '~/types';

import { t } from 'i18next';
import ImageRow from '../../common/ImageRow.astro';
import { fetchAcademyData, fetchCalendarData } from '~/utils/api';
import { FORM } from '~/constants/commons';

type Props = Widget;

const { id, classes = {} } = Astro.props;

const { lang } = Astro.params;
const schedule: Record<string, { time: string; title: string }[]> = await fetchCalendarData(lang);
const academyData = await fetchAcademyData(lang);
---

<div class="!overflow-hidden">
  <ImageRow
    colorClass="bg-purple-500"
    rotateClass="lg:rotate-[-2deg]"
    images={[
      '/images/topRow/2.jpg',
      '/images/topRow/3.jpeg',
      '/images/topRow/4.jpg',
      '/images/topRow/5.jpg',
      '/images/topRow/6.jpg',
      '/images/topRow/7.JPG',
    ]}
  />

  <WidgetWrapper
    id={id}
    containerClass={`max-w-6xl mx-auto mt-[100px] lg:mt-[100px] mb-[100px] lg:mb-[300px] ${classes?.container ?? ''}`}
  >
    <div class="max-w-5xl mx-auto bg-paper flex flex-col gap-20">
      <div class="flex flex-col items-center text-5xl font-primary">{t('academy.calendar.title')}</div>

      <div class="border-t border-black">
        {
          Object.entries(schedule).map(
            ([day, lessons], dayIndex) =>
              lessons.length > 0 && (
                <div
                  class:list={[
                    'grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6 px-6 md:px-8 py-6',
                    dayIndex !== 0 && 'border-t border-black',
                  ]}
                >
                  <div class="font-primary text-3xl font-bold">{day}</div>

                  <div class="md:col-span-3 md:border-l border-black md:pl-6 space-y-3">
                    {lessons.map((lesson) => (
                      <div>
                        <span class="font-primary text-purple-500 font-bold block">{lesson.time}</span>

                        <p class="font-medium">{lesson.title}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )
          )
        }
      </div>
      <div class="flex items-center justify-center mt-[-50px]">
        <a class="btn-header-secondary text-nowrap text-2xl py-2" href={FORM} target="_blank">{t('academy.signin')}</a>
      </div>

      <div class="flex items-start justify-between border-t border-black pt-10">
        <div class="flex flex-col items-start max-w-[450px] text-xl font-delight gap-5">
          <div class="text-5xl font-primary">
            {t('academy.calendar.priceTitle')}
          </div>

          {/* Mobile price */}
          <div class="flex md:hidden text-5xl font-primary">
            {academyData.Price}
          </div>

          <div class="text-xl font-delight">
            {academyData.PriceDescription1}
          </div>

          <div class="text-sm font-delight">
            {academyData.PriceDescription2}
          </div>
        </div>

        {/* Desktop price */}
        <div class="hidden md:flex flex-col items-start text-5xl font-primary">
          {academyData.Price}
        </div>
      </div>
    </div>
  </WidgetWrapper>
</div>

<ImageRow
  colorClass="bg-orange-500"
  rotateClass="lg:rotate-[2deg]"
  offsetClass="ml-[150px] lg:ml-[350px]"
  images={[
    '/images/bottomRow/2.jpg',
    '/images/bottomRow/3.jpg',
    '/images/bottomRow/4.jpg',
    '/images/bottomRow/5.jpg',
    '/images/bottomRow/6.jpg',
    '/images/bottomRow/7.jpg',
  ]}
/>
